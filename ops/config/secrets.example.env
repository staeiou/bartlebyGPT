# Copy to a root-only path (for example /root/bartleby-secrets.env)
# and fill with real values.

# Named Cloudflare tunnel token (optional if tunnel is managed elsewhere)
CLOUDFLARE_TUNNEL_TOKEN=

# Optional vLLM API auth key
VLLM_API_KEY=

# Optional: prebuilt Jetson vLLM wheel release URL + integrity hash.
# If set, bootstrap can download the wheel instead of requiring a local file.
VLLM_WHEEL_URL=
VLLM_WHEEL_SHA256=

# BLE MAC address of the Anker Solix battery (find with: bluetoothctl scan on).
# Required when ENABLE_SOLIX_MONITOR=1.
SOLIX_BLE_ADDR=
