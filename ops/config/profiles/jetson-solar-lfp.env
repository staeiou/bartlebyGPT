# Jetson Orin Nano — LFP12100EK battery (12V 100Ah 1200Wh) + Victron SmartSolar MPPT 100/20

MODEL=staeiou/bartleby-qwen3-1.7b_v4-awq
VLLM_EXTRA_ARGS="--quantization awq_marlin --dtype float16 --gpu-memory-utilization 0.60 --enforce-eager"
VLLM_MAX_MODEL_LEN=2048

# Battery monitor
ENABLE_BATTERY_MONITOR=1
BATTERY_MONITOR_SCRIPT=./ops/services/lfp-monitor/lfp_monitor.py
BATTERY_MONITOR_SERVICE_NAME=lfp-monitor

# JBD BMS (LFP12100EK)
SOLIX_BLE_ADDR=A5:C2:39:1A:5D:29
SOLIX_HOST=127.0.0.1
SOLIX_PORT=18082
SOLIX_CSV_INTERVAL=60
SOLIX_HISTORY_DB_PATH=/opt/bartleby/lfp-monitor/logs/history.sqlite3
SOLIX_CAPACITY_WH=1280
SOLIX_RECONNECT_DELAY=10
SOLIX_MONITOR_WORKDIR=/opt/bartleby/lfp-monitor

# Victron SmartSolar MPPT 100/20 48V
VICTRON_BLE_ADDR=CD:4C:1F:A1:BF:EF
# VICTRON_ENCRYPTION_KEY — set in /root/bartleby-secrets.env

# LFP-specific
LFP_NOMINAL_AH=100

TELEMETRY_POWER_BACKEND=auto
TELEMETRY_ESPHOME_POWER_URL=http://127.0.0.1:18082/sensor/power
TELEMETRY_IDLE_GPU_WATTS=2
TELEMETRY_BASE_SYSTEM_WATTS=0
TELEMETRY_GPU_COOLING_MULTIPLIER=1.00
TELEMETRY_CLAMP_MIN_WATTS=8
TELEMETRY_CLAMP_MAX_WATTS=25
TELEMETRY_HISTORY_24H_BIN_SECONDS=60
TELEMETRY_HISTORY_CACHE_TTL_SECONDS=120
TELEMETRY_HISTORY_DB_PATH=/opt/bartleby/lfp-monitor/logs/history.sqlite3
TELEMETRY_VLLM_LOG_DIR=/opt/bartleby/vllm-metrics
TELEMETRY_BATTERY_CSV_DIR=/opt/bartleby/lfp-monitor/logs
TELEMETRY_BATTERY_CSV_PREFIX=battery
TELEMETRY_SOLIX_STALE_SECONDS=90
TELEMETRY_SOLIX_AUTO_RECOVER=0
TELEMETRY_SOLIX_RECOVERY_COOLDOWN_SECONDS=180
TELEMETRY_SOLIX_RECOVERY_ESCALATE_EVERY=2

DEPLOYMENT_PROFILE=jetson-solar-lfp
BATTERY_CAPACITY_WH=1280

ENABLE_WEB_APP=1
WEB_APP_DIR=./docs
WEB_APP_PUBLIC_DIR=/var/www/bartlebygpt

ENABLE_CLOUDFLARE_TUNNEL=0
CLOUDFLARE_PUBLIC_HOSTNAME=api.bartlebygpt.org
