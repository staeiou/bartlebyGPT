# Raspberry Pi live web+tunnel deployment (process mode, no systemd).

STACK_MODE=process
INFERENCE_BACKEND=llama-server

VLLM_HOST=127.0.0.1
VLLM_PORT=8000
LLAMA_SERVER_BIN=/opt/llama.cpp/build/bin/llama-server
LLAMA_MODEL=/opt/models/bartleby/bartleby-qwen3-1.7b_v4-Q4_K_M.gguf
LLAMA_CTX=512
LLAMA_THREADS=4
LLAMA_PARALLEL=1
LLAMA_EXTRA_ARGS=

ENABLE_WEB_APP=1
WEB_APP_DIR=./docs
WEB_APP_PUBLIC_DIR=/var/www/bartlebygpt

ENABLE_CLOUDFLARE_TUNNEL=1
# Pi default: public hostname fronts nginx (:18201), not raw llama-server (:8000).
CLOUDFLARE_PUBLIC_HOSTNAME=pi.bartlebygpt.org

# Local Solix BLE producer service (installed by bootstrap_fresh_box.sh or bootstrap_solix_monitor.sh).
ENABLE_SOLIX_MONITOR=1
# Device-specific: set SOLIX_BLE_ADDR in your secrets file (/root/bartleby-secrets.env).
SOLIX_BLE_ADDR=
SOLIX_HOST=127.0.0.1
SOLIX_PORT=18082
SOLIX_CSV_INTERVAL=60
SOLIX_HISTORY_DB_PATH=/opt/bartleby/solix-monitor/logs/history.sqlite3
SOLIX_CAPACITY_WH=288

TELEMETRY_POWER_BACKEND=auto
TELEMETRY_ESPHOME_POWER_URL=http://127.0.0.1:18082/sensor/power
TELEMETRY_IDLE_GPU_WATTS=0
TELEMETRY_BASE_SYSTEM_WATTS=0
TELEMETRY_GPU_COOLING_MULTIPLIER=1.00
TELEMETRY_CLAMP_MIN_WATTS=5
TELEMETRY_CLAMP_MAX_WATTS=15
TELEMETRY_HISTORY_DB_PATH=/opt/bartleby/solix-monitor/logs/history.sqlite3
