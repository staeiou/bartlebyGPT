# RTX pod/container profile: foreground process mode (no systemd).

STACK_MODE=process
INFERENCE_BACKEND=vllm

MODEL=staeiou/bartleby-qwen3-1.7b_v4
VLLM_EXTRA_ARGS=
VLLM_MAX_MODEL_LEN=2048

TELEMETRY_POWER_BACKEND=nvidia-smi
TELEMETRY_IDLE_GPU_WATTS=35
TELEMETRY_BASE_SYSTEM_WATTS=120
TELEMETRY_GPU_COOLING_MULTIPLIER=1.00

ENABLE_WEB_APP=0
ENABLE_CLOUDFLARE_TUNNEL=0
